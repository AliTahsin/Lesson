{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-super-secret-key-with-at-least-32-characters-long",
    "Issuer": "HotelAPI",
    "Audience": "HotelClient",
    "ExpirationMinutes": 60
  },
  "RateLimiting": {
    "Enabled": true,
    "GeneralRateLimit": 100,
    "GeneralRateLimitPeriod": "1m",
    "WhitelistedIPs": [
      "127.0.0.1",
      "192.168.1.0/24"
    ]
  },
  "ServiceDiscovery": {
    "Enabled": true,
    "ConsulAddress": "http://localhost:8500",
    "ServiceName": "api-gateway",
    "ServiceAddress": "http://localhost:8080"
  },
  "Services": {
    "HotelManagement": "http://localhost:5000",
    "RoomManagement": "http://localhost:5001",
    "ReservationSystem": "http://localhost:5002",
    "DynamicPricing": "http://localhost:5003",
    "CRMLoyalty": "http://localhost:5004",
    "ChannelManagement": "http://localhost:5005",
    "PaymentInvoice": "http://localhost:5006",
    "Housekeeping": "http://localhost:5007",
    "RestaurantFB": "http://localhost:5008",
    "MICEMeeting": "http://localhost:5009",
    "ReportingBI": "http://localhost:5010",
    "AuthRBAC": "http://localhost:5011",
    "NotificationPush": "http://localhost:5012",
    "AIRecommendation": "http://localhost:5013",
    "ChatbotNLP": "http://localhost:5014",
    "MobileCustomer": "http://localhost:5015",
    "MobileStaff": "http://localhost:5016"
  },
  "ReverseProxy": {
    "Routes": {
      "hotel-management": {
        "ClusterId": "hotel-management-cluster",
        "Match": {
          "Path": "/api/hotels/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/hotels/{**catch-all}" }
        ]
      },
      "room-management": {
        "ClusterId": "room-management-cluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/rooms/{**catch-all}" }
        ]
      },
      "reservation-system": {
        "ClusterId": "reservation-system-cluster",
        "Match": {
          "Path": "/api/reservations/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/reservations/{**catch-all}" }
        ]
      },
      "dynamic-pricing": {
        "ClusterId": "dynamic-pricing-cluster",
        "Match": {
          "Path": "/api/pricing/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pricing/{**catch-all}" }
        ]
      },
      "crm-loyalty": {
