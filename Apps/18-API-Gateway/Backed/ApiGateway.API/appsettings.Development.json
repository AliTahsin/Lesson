{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug",
      "ApiGateway.API.Middlewares": "Debug"
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "GeneralRateLimit": 1000,
    "GeneralRateLimitPeriod": "1m",
    "WhitelistedIPs": [
      "127.0.0.1",
      "localhost",
      "192.168.1.0/24"
    ]
  },
  "ServiceDiscovery": {
    "Enabled": true,
    "ConsulAddress": "http://localhost:8500",
    "ServiceName": "api-gateway-dev",
    "ServiceAddress": "http://localhost:8080",
    "HealthCheckIntervalSeconds": 30
  },
  "Jwt": {
    "Key": "dev-super-secret-key-for-development-only-32-chars",
    "Issuer": "HotelAPI-Dev",
    "Audience": "HotelClient-Dev",
    "ExpirationMinutes": 60
  },
  "Services": {
    "HotelManagement": "http://localhost:5000",
    "RoomManagement": "http://localhost:5001",
    "ReservationSystem": "http://localhost:5002",
    "DynamicPricing": "http://localhost:5003",
    "CRMLoyalty": "http://localhost:5004",
    "ChannelManagement": "http://localhost:5005",
    "PaymentInvoice": "http://localhost:5006",
    "Housekeeping": "http://localhost:5007",
    "RestaurantFB": "http://localhost:5008",
    "MICEMeeting": "http://localhost:5009",
    "ReportingBI": "http://localhost:5010",
    "AuthRBAC": "http://localhost:5011",
    "NotificationPush": "http://localhost:5012",
    "AIRecommendation": "http://localhost:5013",
    "ChatbotNLP": "http://localhost:5014",
