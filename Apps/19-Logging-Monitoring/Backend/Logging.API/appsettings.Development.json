{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-dev-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "DefaultIndex": "hotel-logs-dev"
  },
  "Prometheus": {
    "Enabled": true,
    "Endpoint": "/metrics"
  },
  "Jaeger": {
    "Enabled": true,
    "AgentHost": "localhost",
    "AgentPort": 6831,
    "ServiceName": "logging-api-dev"
  }
}