{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-super-secret-key-with-at-least-32-characters-long",
    "Issuer": "StaffAPI",
    "Audience": "StaffClient",
    "ExpirationHours": 8
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=StaffDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "SignalR": {
    "Backplane": "redis://localhost:6379"
  },
  "PushNotifications": {
    "FirebaseServerKey": "your-firebase-server-key",
    "FirebaseSenderId": "your-firebase-sender-id"
  }
}